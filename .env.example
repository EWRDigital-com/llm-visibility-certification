# Copy to .env and fill in. .env is gitignored — never commit real keys.

# --- Scraper (Phase 0 CLI + the audit worker) ---
# Firecrawl is OPTIONAL: the scraper free-fetches by default. A key only adds
# JS-rendering for anti-bot/SPA sites. Get one at https://firecrawl.dev.
FIRECRAWL_API_KEY=

# --- Supabase (Phase 1a: submissions, audits, scores, certificates) ---
# Server-only. The service-role key bypasses RLS — NEVER expose it to the browser.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Magic-link auth ---
# 32+ random bytes; signs the email confirmation token (HMAC-SHA256).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MAGIC_LINK_SECRET=

# --- Transactional email (magic link) ---
# If RESEND_API_KEY is unset, the app logs the magic link to the server console
# instead of sending (fine for local dev). Set both to actually send.
RESEND_API_KEY=
EMAIL_FROM="LLM Visibility <noreply@llmvisibilitycertification.com>"

# --- App ---
# Public base URL used to build magic links (no trailing slash).
NEXT_PUBLIC_APP_URL=http://localhost:3000
